#
# Kconfig.projbuild — AIYIMA A800X DSP Controller
#

menu "A800X DSP Controller"

    config A800X_USB_VID
        hex "MVSilicon USB VID"
        default 0x8888
        help
            USB Vendor ID des MVSilicon-Geräts.

    config A800X_USB_PID
        hex "MVSilicon USB PID"
        default 0x171E
        help
            USB Product ID des MVSilicon-Geräts.

    config A800X_HID_REPORT_SIZE
        int "HID Report Size (Bytes)"
        default 256
        help
            Größe des HID SET_REPORT in Bytes.

    config A800X_USB_DEVICE_WAIT_MS
        int "USB Device Wait Time (ms)"
        default 3000
        help
            Wartezeit nach Power-On, bis der DSP gebootet ist.

    config A800X_DIAGNOSTIC_NS_BOOT_TEST
        bool "Noise-Suppressor-Schalttest beim USB-Connect"
        default n
        help
            Expliziter Diagnosemodus. Schaltet den Noise Suppressor beim
            Verbinden AUS und wieder EIN. Im normalen Betrieb deaktiviert.

    config A800X_WIFI_SETUP_TIMEOUT_S
        int "WiFi Setup Window (seconds)"
        default 180
        help
            Zeitfenster für WiFi-Setup nach Power-On (0 = unbegrenzt).

    config A800X_MDNS_DEFAULT_HOSTNAME
        string "Default mDNS Hostname prefix"
        default "a800x"
        help
            Präfix für den mDNS-Hostnamen. Die MAC-Kurzform wird angehängt.

    config A800X_HTTP_PORT
        int "HTTP Server Port"
        default 80
        help
            Port des integrierten Webservers.

    config A800X_NVS_NAMESPACE
        string "NVS Namespace"
        default "a800x"
        help
            NVS-Namespace für alle Einstellungen.

    config A800X_MAX_PROFILES
        int "Maximum DSP Profile Count"
        default 8
        range 1 32
        help
            Maximale Anzahl speicherbarer DSP-Profile.

endmenu
